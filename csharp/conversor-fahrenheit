double temperaturaCelcius, temperaturaFahrenheit; 
Console.WriteLine("Informe  a  temperatura em Celcius"); 
temperaturaCelcius = Convert.ToDouble(Console.ReadLine()); 
temperaturaFahrenheit = temperaturaCelcius * 1.8 + 32; 
Console.WriteLine($"A temperatura {temperaturaCelcius} graus Celcius é equivalente " + 
                  $"a {temperaturaFahrenheit} graus Fahrenheit");
